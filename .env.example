# =====================================================================
# AMEVA Edge Agent - 환경 설정 템플릿 예시 파일 (.env.example)
# =====================================================================

# 1. 에이전트 기본 저장소 경로 설정 (Termux 기기 기준 기본 경로)
AMEVA_AGENT_DIR=/data/data/com.termux/files/home/dev/ameva-agent

# 2. whisper.cpp 설정
# whisper.cpp 컴파일된 CLI 바이너리 절대 경로 및 다운로드 받은 모델 바이너리 경로
WHISPER_BIN=/data/data/com.termux/files/home/dev/whisper.cpp/main
WHISPER_MODEL=/data/data/com.termux/files/home/dev/whisper.cpp/models/ggml-small.bin

# 3. bitnet.cpp 설정
# 1-bit LLM 실행기 절대 경로 및 모델 경로
BITNET_BIN=/data/data/com.termux/files/home/dev/bitnet.cpp/main
BITNET_MODEL=/data/data/com.termux/files/home/dev/bitnet.cpp/models/Llama3-8B-1.58b/ggml-model-i2_s.gguf

# 4. Ollama (워크어라운드) 설정
# 로컬 LLM 구동을 위해 bitnet.cpp 백업으로 구동될 Ollama 호스트, 포트, 모델 설정
OLLAMA_BIN=ollama
OLLAMA_HOST=127.0.0.1
OLLAMA_PORT=11434
OLLAMA_MODEL=llama3.2:3b

# 5. SSH/SCP 전송 설정 (실제 수신 서버 정보 작성 필요)
# 파일을 전송해 받을 서버 정보 및 인증서 경로
SSH_HOST=192.168.1.100
SSH_PORT=22
SSH_USER=backup_user
SSH_KEY=/data/data/com.termux/files/home/.ssh/id_rsa
SSH_REMOTE_PATH=/home/backup_user/received_files

# 6. 정기 일배치 실행 시간 설정
# 파일 동기화 배치 시각 (매일 21:00)
FILE_SYNC_TIME=21:00
# DB 마이그레이션 배치 시각 (매일 23:00)
DB_SYNC_TIME=23:00

# 7. 성능 및 보안 설정
# 모바일 자원 절약을 위한 STT 처리 병렬 워커 개수 (기본 1 권장)
MAX_WORKERS=1
# 포렌식 복구 불가능 영구 파쇄를 위한 디스크 덮어쓰기 횟수 (기본 3회)
SHRED_PASSES=3
